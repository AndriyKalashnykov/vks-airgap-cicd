@startuml pipeline-flow
!include c4/C4_Dynamic.puml
!include _style.puml

' Folded 2-lane layout (CI intake on top, GitOps/CD lane below) via directional
' Rel_* hints — NOT LAYOUT_LEFT_RIGHT: the 8-step chain as one wide row rendered a
' ~4200px strip that clipped at PlantUML's 4096px default (PLANTUML_LIMIT_SIZE),
' truncating the javawebapp node + legend, AND embedded as a thin sliver. Folding keeps
' it complete and balanced. The render also raises PLANTUML_LIMIT_SIZE well above
' 4096 (see Makefile _render_diagrams) so no diagram can silently clip again.

title Pipeline flow — a push to production, inside the air gap

Person(dev, "Developer")
Container(gitea_app, "Gitea: javawebapp-app", "git repo")
Container(el, "Tekton EventListener", "el-javawebapp")
Container(pipe, "Tekton PipelineRun", "clone · test · build · write-back")
ContainerDb(harbor, "Harbor", "OCI registry", $tags="datastore")
Container(gitea_dep, "Gitea: javawebapp-deploy", "git repo")
Container(argo, "ArgoCD", "GitOps")
Container(app, "javawebapp", "Deployment + Service")

Rel_R(dev, gitea_app, "1. git push")
Rel_R(gitea_app, el, "2. push webhook")
Rel_R(el, pipe, "3. create PipelineRun")
Rel(pipe, pipe, "4. mvn test (offline)")
Rel_R(pipe, harbor, "5. kaniko build + push image")
Rel_D(pipe, gitea_dep, "6. commit new image tag")
Rel_R(gitea_dep, argo, "7. auto-sync detects change")
Rel_R(argo, app, "8. deploy new version")
Rel_D(harbor, app, "pull image")

SHOW_LEGEND()
@enduml
