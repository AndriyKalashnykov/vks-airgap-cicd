@startuml istio-ingress
!include c4/C4_Deployment.puml
!include _style.puml
LAYOUT_TOP_DOWN()

title Istio ingress — two scenarios: we INSTALL the mesh, or we ATTACH to one we did not install

' ---------------------------------------------------------------------------
' Every label here describes what the REPO actually does (scripts/46, scripts/47, k8s/istio/*).
' Broadcom ships Istio as a VKS STANDARD PACKAGE on the guest cluster (verified: TechDocs +
' the VMware VCF blog) — so on a real lab Scenario 2 is the one that applies, and the KinD
' stand-in is what exercises Scenario 1. See docs/decisions/istio-on-vks.md.
' ---------------------------------------------------------------------------

Person(op, "Operator / browser", "resolves *.vks.local via /etc/hosts -> INGRESS_LB_IP")

Deployment_Node(s1, "SCENARIO 1 — we INSTALL Istio   (INGRESS_CONTROLLER=istio, default)", "guest cluster · scripts/46-install-istio.sh · we OWN the mesh") {
  Deployment_Node(s1cp, "namespace: istio-system", "helm istio/base + istio/istiod") {
    Container(s1istiod, "istiod", "control plane\nimages from Harbor (global.hub)\nsidecar injection DISABLED")
  }
  Deployment_Node(s1gw, "namespace: istio-ingress", "helm istio/gateway · release istio-ingressgateway") {
    Container(s1envoy, "ingress gateway (Envoy)", "Service type LoadBalancer\nselector label PINNED by us:\nlabels.istio=ingressgateway")
  }
  Deployment_Node(s1routes, "our route objects", "applied by scripts/lib/istio.sh") {
    Container(s1g, "Gateway  vks-uis", "in the gateway ns\nselector: istio=ingressgateway")
    Container(s1vs, "VirtualServices", "one per UI, in the BACKEND's namespace\ngateways: <gw-ns>/vks-uis")
  }
}

Deployment_Node(s2, "SCENARIO 2 — the platform ALREADY installed Istio   (INGRESS_CONTROLLER=istio-existing)", "guest cluster · scripts/47-attach-istio.sh · we install NOTHING") {
  Deployment_Node(s2cp, "namespace: <theirs>", "installed and owned by the platform team") {
    Container(s2istiod, "istiod", "we only READ it\n(version = the running image tag)")
  }
  Deployment_Node(s2gw, "namespace: <theirs>  (classic path only)", "their helm release — name unknown to us; MAY NOT EXIST:\nthe VKS Istio package ships the shared gateway OFF by default") {
    Container(s2envoy, "their ingress gateway (Envoy)", "DISCOVERED: the Service exposing port 15021\nwith a spec.selector.istio key\n(istiod has no 15021 — that is what excludes it)")
  }
  Deployment_Node(s2auto, "namespace: OURS  (gateway-api path)", "Istio provisions this FOR us — no mesh-admin rights needed") {
    Container(s2autogw, "<gateway>-istio (Envoy) + its LoadBalancer", "auto-created from our Gateway resource.\nPulls proxyv2 from the MESH's hub (attach) / our Harbor (we-install).\nAttached + authed registry -> needs a pull-secret in THIS ns\n(named in the mesh's meshConfig.imagePullSecrets)")
  }
  Deployment_Node(s2routes, "the ONLY things we create — ISTIO_ROUTE_API picks the API", "auto: prefer Gateway API, else classic") {
    Container(s2g, "PREFERRED: Gateway API\n(gatewayClassName: istio)", "a Gateway in OUR namespace + HTTPRoutes.\nIstio AUTO-PROVISIONS the proxy AND its LoadBalancer\n-> no GATEWAY needed from the mesh admin.\nPRECONDITION: the Gateway API CRDs must exist.\nThey are CLUSTER-SCOPED, so a tenant cannot install them.\nVKS 9.1 guest clusters SHIP them by default (VKr-managed, 9.1-doc).\nWe install them when we own the cluster (carried bundle, air-gap clean);\nif ABSENT a tenant must ASK the mesh admin.\nOpen risk (B2): the VERSION we pin vs the VKr's, not presence.\nAttach: proxy image comes from the mesh's hub; authed registry needs a pull-secret (see istio.md sec.4).\nWorks even though the VKS package ships the shared gateway OFF.")
    Container(s2vs, "FALLBACK: classic\n(Gateway + VirtualService)", "binds an EXISTING gateway workload:\nselector istio=<DISCOVERED label> (chart derives it\nfrom the HELM RELEASE NAME -> NOT 'ingressgateway'),\nor reuse theirs: ISTIO_SHARED_GATEWAY=<ns>/<name>")
  }
}

Deployment_Node(be, "Backend Services (both scenarios)", "NO sidecars — the gateway proxies straight to each ClusterIP.\nOne route per BACKEND, each in its backend's namespace;\nthe APP routes come from apps/registry.tsv (gitea + the dashboard are not apps)") {
  Container(bgitea, "gitea", "gitea.vks.local")
  Container(bapp, "javawebapp", "javawebapp.vks.local")
  Container(bapp2, "gowebapp", "gowebapp.vks.local")
  Container(btkn, "tekton-dashboard", "tekton.vks.local")
}

Rel(op, s1envoy, "http://*.vks.local", "one LoadBalancer IP")
Rel(op, s2autogw, "http://*.vks.local", "the LB Istio auto-provisioned for US")
Rel(op, s2envoy, "http://*.vks.local", "(classic path) their LoadBalancer IP")
Rel(s1g, s1envoy, "binds (selector matches)")
Rel(s2g, s2autogw, "Istio AUTO-PROVISIONS this from our Gateway")
Rel(s2vs, s2envoy, "binds ONLY with the DISCOVERED selector label")
Rel(s1vs, s1g, "gateways: <gw-ns>/<name>")
Rel(s1envoy, bapp, "routes to each app's ClusterIP")
Rel(s1envoy, bapp2, "routes to each app's ClusterIP")
Rel(s2autogw, bapp, "routes to each app's ClusterIP")
Rel(s2autogw, bapp2, "routes to each app's ClusterIP")
Rel(s2envoy, bapp, "routes to each app's ClusterIP")
Rel(s2envoy, bapp2, "routes to each app's ClusterIP")

SHOW_LEGEND()
@enduml
