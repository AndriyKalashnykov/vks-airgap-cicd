@startuml deployment
!include c4/C4_Deployment.puml
!include _style.puml
LAYOUT_LEFT_RIGHT()

title Deployment — jump box + air-gapped VKS cluster

Person(op, "Operator", "browses the UIs at *.vks.local")

Deployment_Node(jb, "Jump box", "Ubuntu or PhotonOS · internet-connected") {
  Container(cli, "Toolchain", "mise, crane, podman/docker, kubectl, tkn, argocd, helm")
  Container(mir, "Mirror + builder", "crane copy · builder image build")
}

Deployment_Node(vks, "VKS workload cluster", "VMware vSphere Kubernetes Service · air-gapped") {
  Deployment_Node(ns_harbor, "namespace: harbor (VKS-provided)", "") {
    ContainerDb(harbor, "Harbor", "OCI registry, LoadBalancer", $tags="datastore")
  }
  Deployment_Node(ns_gitea, "namespace: gitea", "") {
    Container(gitea, "Gitea", "Deployment + PVC (SQLite)")
  }
  Deployment_Node(ns_tk, "namespace: tekton-pipelines", "") {
    Container(tk, "Tekton", "Pipelines + Triggers controllers")
    Container(dash, "Tekton Dashboard", "read-only web UI")
  }
  Deployment_Node(ns_ci, "namespace: ci", "") {
    Container(ci, "Pipeline + EventListener", "PipelineRuns, el-webui")
  }
  Deployment_Node(ns_argo, "namespace: argocd (VKS-provided)", "") {
    Container(argo, "ArgoCD", "Application controller")
  }
  Deployment_Node(ns_app, "namespace: webui", "") {
    Container(app, "webui", "Deployment (2 replicas) + Service")
  }
  Deployment_Node(ns_ing, "namespace: istio-ingress | traefik", "") {
    Container(ing, "Ingress gateway", "LoadBalancer · INGRESS_CONTROLLER=istio (default) | traefik")
  }
}

Rel(mir, harbor, "push images", "HTTPS (self-signed + CA)")
Rel(cli, gitea, "install + seed", "kubectl")
Rel(cli, tk, "install", "kubectl")
Rel(ci, harbor, "build+push / pull", "kaniko / containerd (TLS + CA)")
Rel(ci, gitea, "clone + write-back", "git")
Rel(argo, gitea, "sync from webui-deploy", "git")
Rel(argo, app, "deploy", "kubectl")
Rel(app, harbor, "pull image", "containerd (TLS + CA)")
Rel(op, ing, "browse Gitea / Tekton / app UIs", "*.vks.local / HTTP")
Rel(ing, gitea, "route", "HTTP")
Rel(ing, app, "route", "HTTP")
Rel(ing, dash, "route", "HTTP")
Rel(op, argo, "browse ArgoCD (own LB)", "HTTPS (self-signed)")
Rel(op, harbor, "browse Harbor (own LB)", "HTTPS (self-signed)")

SHOW_LEGEND()
@enduml
