# ---- Local operator overrides / secrets (NEVER commit) ----
.env
.env.*
!.env.example

# ---- Air-gap bundle + mirrored artifacts (large, regenerated) ----
/bundle/
*.tar
*.tar.gz
*.tar.zst

# ---- Kubeconfigs / credentials pulled at runtime ----
kubeconfig
*.kubeconfig
/secrets/
*.pem
*.key
!**/testdata/**/*.key

# ---- Java build output ----
target/
*.class
*.jar
!**/.mvn/wrapper/maven-wrapper.jar

# ---- PlantUML JVM font-cache litter (from an unset HOME in the render container) ----
docs/diagrams/[?]/
docs/diagrams/.check/

# ---- Tooling / editor ----
.idea/
.vscode/
*.iml
.DS_Store
mise.local.toml

# Jump-box harness runtime (internal kubeconfig)
.jumpbox/

# Operator-local download links (external, licensed artifacts) — not committed
links.md

# Operator-local Broadcom download token (live credential) — NEVER commit
token.md

# Claude Code harness (agent worktrees, local state) — never tracked/scanned
# Ignore the harness's scratch (worktrees, local settings) — but NOT the repo's own agent
# DEFINITIONS: the VKS adversarial reviewer is a STOPPING RULE for every session (see CLAUDE.md),
# so it must travel with the repo. (A negation cannot re-include a file under an EXCLUDED DIR, so
# exclude the CONTENTS, not the directory.)
.claude/*
!.claude/agents/

# Serializes registry-mutating work (see with_registry_lock in scripts/lib/os.sh)
.registry.lock
