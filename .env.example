# =============================================================================
# vks-airgap-cicd — committed source of truth for every operator-tunable value.
#
# HOW TO USE
#   cp .env.example .env      # then edit .env with your air-gap specifics
#   .env is gitignored (per-operator overrides + secrets); this file is not.
#   Both the Makefile (-include .env) and scripts (they source these) read it.
#
# CONVENTIONS
#   - Non-secret values carry a real default here.
#   - Secrets are COMMENTED placeholders (`<SET-IN-.env>`): set them only in .env
#     so they are never committed and never appear in `git`/`docker inspect`.
#   - Keep this file shell-clean: KEY=value, no spaces around '=', no quotes
#     needed unless the value has spaces. Escape a literal '$' as '$$' for Make.
# =============================================================================

# -----------------------------------------------------------------------------
# 0. Run mode
# -----------------------------------------------------------------------------
# dual-homed : jump box reaches both internet AND the VKS/Harbor network.
# sneakernet : jump box only has internet; produces a bundle carried inside.
RUN_MODE=dual-homed

# -----------------------------------------------------------------------------
# 1. Harbor (registry) — PROVIDED by VKS, known IP/DNS
# -----------------------------------------------------------------------------
HARBOR_URL=harbor.vks.local
# Project for mirrored CI/CD + build-base infra images (Tekton, Gitea, Kaniko, temurin...)
HARBOR_INFRA_PROJECT=cicd
# Project for the built application image
HARBOR_APP_PROJECT=apps
# Path to the Harbor CA cert (self-signed). Used for skopeo/kaniko/podman trust.
HARBOR_CA_FILE=./secrets/harbor-ca.crt
# Robot/admin account used to push mirrored images + let the pipeline push builds.
HARBOR_USERNAME=admin
# HARBOR_PASSWORD=<SET-IN-.env>

# -----------------------------------------------------------------------------
# 2. Gitea (self-hosted Git) — WE INSTALL on VKS
# -----------------------------------------------------------------------------
GITEA_NAMESPACE=gitea
# External URL (humans + webhook registration UI).
GITEA_URL=http://gitea.vks.local
# In-cluster URL used by Tekton (clone/write-back) and ArgoCD (repo) — resolves
# via kube-DNS to the Gitea Service. Matches the Gitea Helm chart's http service.
GITEA_INTERNAL_URL=http://gitea-http.gitea.svc:3000
GITEA_CA_FILE=./secrets/gitea-ca.crt
GITEA_ORG=demo
GITEA_APP_REPO=webui-app
GITEA_DEPLOY_REPO=webui-deploy
GITEA_ADMIN_USER=gitea_admin
# GITEA_ADMIN_PASSWORD=<SET-IN-.env>
# Persistent volume size for Gitea data (SQLite DB + repos).
GITEA_STORAGE_SIZE=5Gi
# CI user Tekton/ArgoCD use to clone + push (write-back). A PAT is minted at seed time.
GITEA_CI_USER=ci-bot
# GITEA_CI_PASSWORD=<SET-IN-.env>
# GITEA_CI_TOKEN=<SET-IN-.env — minted by scripts/50-seed-gitea-repos.sh>

# -----------------------------------------------------------------------------
# 3. Tekton — WE INSTALL on VKS
# -----------------------------------------------------------------------------
TEKTON_NAMESPACE=tekton-pipelines
# Namespace where the pipeline, triggers, and EventListener run.
CI_NAMESPACE=ci

# -----------------------------------------------------------------------------
# 4. ArgoCD (GitOps CD) — PROVIDED by VKS
# -----------------------------------------------------------------------------
ARGOCD_NAMESPACE=argocd
ARGOCD_SERVER=argocd.vks.local
ARGOCD_APP_NAME=webui
# Namespace the demo app is deployed INTO by ArgoCD.
ARGOCD_DEST_NAMESPACE=webui
# Branch in webui-deploy that ArgoCD tracks (must be a branch, not a tag/commit,
# so the Tekton write-back commit is picked up automatically).
ARGOCD_TRACK_BRANCH=main

# -----------------------------------------------------------------------------
# 4b. Ingress (WE install it) — ONE LoadBalancer fronting the browser UIs at
#     *.vks.local so operators reach Gitea/ArgoCD/the app by hostname instead of
#     `kubectl port-forward`. Air-gap honest: hostnames resolve via /etc/hosts on
#     the jump box/clients -> the ingress LB IP (NO internet DNS / sslip.io).
#     Harbor keeps its OWN direct LoadBalancer (its LB IP is load-bearing for the
#     containerd insecure-registry pull path — see 06-install-harbor.sh).
#
#     Pluggable: INGRESS_CONTROLLER selects the implementation. `istio` (default)
#     installs the Istio control plane + ingress gateway (images from Harbor via
#     the helm hub override); `traefik` installs the lighter single-binary Traefik.
#     Both expose the SAME *.vks.local hostnames and one LB IP.
# -----------------------------------------------------------------------------
INGRESS_CONTROLLER=istio
# Ingress hostnames (keep the host part aligned with GITEA_URL / ARGOCD_SERVER).
GITEA_HOST=gitea.vks.local
ARGOCD_HOST=argocd.vks.local
WEBUI_HOST=app.vks.local
TEKTON_DASHBOARD_HOST=tekton.vks.local
# --- Istio (INGRESS_CONTROLLER=istio) ---
# ISTIO_VERSION must match images/images.txt istio/pilot + istio/proxyv2 tags;
# Renovate bumps it in lockstep with them (Docker images group), and
# check-image-alignment is the deterministic backstop.
# renovate: datasource=docker depName=istio/pilot
ISTIO_VERSION=1.30.2
ISTIO_NAMESPACE=istio-system
ISTIO_GATEWAY_NAMESPACE=istio-ingress
# --- Traefik (INGRESS_CONTROLLER=traefik) ---
TRAEFIK_NAMESPACE=traefik

# -----------------------------------------------------------------------------
# 5. Demo application
# -----------------------------------------------------------------------------
APP_NAME=webui
# Branch of webui-app that a push triggers CI on.
APP_BRANCH=main
# Container port the app binds inside the pod / container.
APP_INTERNAL_PORT=8080
# Host port for LOCAL dev runs (mvn spring-boot:run / java -jar). check-ports guards it.
APP_DEV_PORT=8080
# Replicas ArgoCD deploys.
APP_REPLICAS=2
# Air-gap Maven builder image tag (deps pre-baked; built by scripts/15-build-push-builder.sh).
# Its ref is derived as $HARBOR_URL/$HARBOR_INFRA_PROJECT/webui-builder:$BUILDER_IMAGE_TAG.
# Rebuild + bump when apps/java/webui/pom.xml dependencies change.
BUILDER_IMAGE_TAG=0.3.0

# -----------------------------------------------------------------------------
# 6. VKS access (VCF 9 + Supervisor) — auth method TBD (see scripts/30-vks-login.sh)
# -----------------------------------------------------------------------------
# Everything downstream only needs a working KUBECONFIG + context. 30-vks-login.sh
# is the single pluggable step that produces them.
KUBECONFIG=./secrets/vks.kubeconfig
VKS_CONTEXT=vks-workload
# --- VCF-CLI login inputs (populate once the contractor confirms the method) ---
# SUPERVISOR_HOST=<SET-IN-.env>       # Supervisor / VCF endpoint
# VKS_NAMESPACE=<SET-IN-.env>         # vSphere namespace hosting the workload cluster
# VKS_CLUSTER_NAME=<SET-IN-.env>      # VKS workload cluster name
# VKS_USERNAME=<SET-IN-.env>
# VKS_PASSWORD=<SET-IN-.env>

# -----------------------------------------------------------------------------
# 7. Air-gap bundle (sneakernet)
# -----------------------------------------------------------------------------
BUNDLE_DIR=./bundle
# Local dir skopeo pulls OCI layouts into before bundling / pushing.
IMAGE_CACHE_DIR=./bundle/images
# Mirror only this CPU architecture by default (matches the VKS/kind nodes) — keeps
# the cache ~5x smaller and mirroring much faster. Digest-pinned images (Tekton)
# are always mirrored multi-arch to preserve their list digest.
MIRROR_ARCH=amd64
# Set to 1 to mirror ALL architectures (larger, slower).
MIRROR_ALL_ARCH=0

# -----------------------------------------------------------------------------
# 8. Tunable timings (readiness polling, HTTP checks) — seconds unless noted
# -----------------------------------------------------------------------------
READY_TIMEOUT_SECONDS=300
POLL_INTERVAL_SECONDS=5
CURL_MAX_TIME_SECONDS=10
# Resilient HTTP GET (http_get_retry) — used for transient-prone internet
# fetches like the ArgoCD install manifest from raw.githubusercontent.com,
# which rate-limits (HTTP 429). Retries with exponential backoff.
HTTP_GET_RETRIES=5
HTTP_GET_RETRY_DELAY_SECONDS=5
HTTP_CONNECT_TIMEOUT_SECONDS=10
HTTP_GET_MAX_TIME_SECONDS=60

# -----------------------------------------------------------------------------
# 9. Pinned component versions (mirror of images/images.txt + .mise.toml)
#    Keep these aligned with images/images.txt; Renovate tracks the image tags.
# -----------------------------------------------------------------------------
# renovate: datasource=github-releases depName=tektoncd/pipeline
TEKTON_PIPELINES_VERSION=v1.14.0
# renovate: datasource=github-releases depName=tektoncd/triggers
TEKTON_TRIGGERS_VERSION=v0.36.0
# Tekton Dashboard — the web UI for PipelineRuns/TaskRuns/logs, at TEKTON_DASHBOARD_HOST.
# Installed READ-ONLY (release.yaml; no mutation from the UI). The Dashboard has NO built-in
# auth — access is network/ingress-gated, so it needs no login (see .trivyignore rationale
# and the README "Access the UIs" note). Its image is mirrored from ghcr.io like the other
# Tekton controllers (derived from the release manifest, not images.txt).
# renovate: datasource=github-releases depName=tektoncd/dashboard
TEKTON_DASHBOARD_VERSION=v0.70.0
# The app RUNTIME image (eclipse-temurin JRE). Renovate-tracked in lockstep with
# images/images.txt; check-image-alignment fails CI if it drifts, and
# check-java-alignment fails if its major diverges from apps/java/webui/pom.xml's java.version.
# (Only the JRE is mirrored — the in-cluster BUILD uses the maven:...-temurin image,
# so no standalone temurin JDK is needed.)
# renovate: datasource=docker depName=eclipse-temurin
TEMURIN_JRE_TAG=25.0.3_9-jre-jammy
# CLI tools not covered by mise (downloaded by scripts/00-install-prereqs.sh).
# renovate: datasource=github-releases depName=tektoncd/cli extractVersion=^v(?<version>.*)$
TKN_VERSION=0.45.0
# The argocd CLI SHOULD match the ArgoCD server (ARGOCD_VERSION) major line — same
# argoproj/argo-cd product. Keep this aligned with ARGOCD_VERSION below; Renovate
# tracks both (same depName) and bumps them together.
# renovate: datasource=github-releases depName=argoproj/argo-cd
ARGOCD_CLI_VERSION=v3.4.4
# kubectl fallback version (only used by 00-install-prereqs.sh if mise didn't
# provide it). Kept aligned with .mise.toml's kubectl pin by check-toolchain-alignment.
# renovate: datasource=github-releases depName=kubernetes/kubernetes
KUBECTL_VERSION=v1.36.2

# -----------------------------------------------------------------------------
# 10. KinD local end-to-end (simulates the "VKS-provided" Harbor + ArgoCD locally)
#     Used only by `make e2e-kind` / kind-* targets. On real VKS these are given.
#     The kind flow writes discovered values (HARBOR_URL, KUBECONFIG, ...) to a
#     gitignored .env.kind overlay that overrides the values above.
# -----------------------------------------------------------------------------
KIND_CLUSTER_NAME=vks-airgap-cicd
# Empty = use the kind binary's built-in (version-locked) default node image.
KIND_NODE_IMAGE=
# renovate: datasource=github-releases depName=kubernetes-sigs/cloud-provider-kind
CLOUD_PROVIDER_KIND_VERSION=v0.11.1
# renovate: datasource=helm depName=harbor registryUrl=https://helm.goharbor.io
HARBOR_CHART_VERSION=1.19.1
HARBOR_NAMESPACE=harbor
# renovate: datasource=github-releases depName=argoproj/argo-cd
ARGOCD_VERSION=v3.4.4
# ArgoCD 'admin' UI password for the LOCAL KinD ArgoCD. KinD ONLY — on real VKS,
# ArgoCD is provided by the lab with a lab-set password, so leave this blank there.
# Optional: set it (in .env, like GITEA_ADMIN_PASSWORD / HARBOR_PASSWORD) for a known,
# stable login; the KinD install applies it. Leave blank/commented to keep ArgoCD's
# auto-generated password — either way `make argocd-password` / `make creds` reveal it
# (they self-resolve the kubeconfig, so no kube-context juggling). Commented so it stays
# unset by default and the generated-password fallback works.
# ARGOCD_ADMIN_PASSWORD=<SET-IN-.env>
